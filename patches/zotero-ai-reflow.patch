diff --git a/chrome/content/zotero/xpcom/aiReflow.js b/chrome/content/zotero/xpcom/aiReflow.js
new file mode 100644
index 0000000..00060f5
--- /dev/null
+++ b/chrome/content/zotero/xpcom/aiReflow.js
@@ -0,0 +1,1235 @@
+/*
+    Local SciReader bridge for PDF attachments.
+*/
+
+Zotero.AIReflow = new function () {
+	this.baseURL = 'http://127.0.0.1:27621';
+	this.columnPluginID = 'scireader@local';
+	this.aiExtraKeys = ['Venue', 'CCF', 'SCI', 'JCR', 'RankScore', 'Stars', 'CodeStatus', 'CodeURL', 'CodeEvidence', 'Evidence'];
+	this.summaryNoteTitle = 'SciReader 论文总结';
+	this._summaryNoteTasks = new Set();
+	this._metadataTasks = new Set();
+	this._metadataSyncTasks = new Set();
+	this._progressTasks = new Map();
+	this._columnsRegistered = false;
+
+	this.isProgressEnabled = function () {
+		try {
+			return Zotero.Prefs.get('aiReflow.showProgress') !== false;
+		}
+		catch (e) {
+			return true;
+		}
+	};
+
+	this.setProgressEnabled = function (enabled) {
+		Zotero.Prefs.set('aiReflow.showProgress', !!enabled);
+		if (!enabled) {
+			this.closeAllProgress();
+		}
+	};
+
+	this.disableNativeCloudSync = function () {
+		for (let [key, value] of [
+			['streaming.enabled', false],
+			['sync.autoSync', false],
+			['sync.storage.enabled', false],
+			['sync.reminder.setUp.enabled', false],
+			['sync.reminder.autoSync.enabled', false],
+			['automaticScraperUpdates', false]
+		]) {
+			try {
+				Zotero.Prefs.set(key, value);
+			}
+			catch (e) {}
+		}
+	};
+
+	this.configureSettings = async function () {
+		let status = {};
+		try {
+			status = await this.jsonRequest(`${this.baseURL}/api/config`, { timeout: 10000 });
+		}
+		catch (e) {}
+		let deepseek = { value: '' };
+		let easyscholar = { value: '' };
+		let webdavURL = { value: status.webdavUrl || 'https://dav.jianguoyun.com/dav/' };
+		let webdavUser = { value: status.webdavUser || '' };
+		let webdavPassword = { value: '' };
+		let check = { value: false };
+		let ok = Services.prompt.promptPassword(
+			null,
+			'SciReader DeepSeek Key',
+			'输入新的 DeepSeek API Key（留空则不修改）：',
+			deepseek,
+			'',
+			check
+		);
+		if (!ok) {
+			return;
+		}
+		ok = Services.prompt.promptPassword(
+			null,
+			'SciReader easyScholar Key',
+			'输入新的 easyScholar SecretKey（留空则不修改）：',
+			easyscholar,
+			'',
+			check
+		);
+		if (!ok) {
+			return;
+		}
+		ok = Services.prompt.prompt(
+			null,
+			'SciReader WebDAV',
+			'WebDAV 服务器地址：',
+			webdavURL,
+			'',
+			check
+		);
+		if (!ok) {
+			return;
+		}
+		ok = Services.prompt.prompt(
+			null,
+			'SciReader WebDAV',
+			'WebDAV 账号：',
+			webdavUser,
+			'',
+			check
+		);
+		if (!ok) {
+			return;
+		}
+		ok = Services.prompt.promptPassword(
+			null,
+			'SciReader WebDAV',
+			'WebDAV 应用密码（留空则不修改）：',
+			webdavPassword,
+			'',
+			check
+		);
+		if (!ok) {
+			return;
+		}
+		try {
+			let response = await this.postJSON('/api/config', {
+				deepseekKey: deepseek.value,
+				easyScholarKey: easyscholar.value,
+				webdavUrl: webdavURL.value,
+				webdavUser: webdavUser.value,
+				webdavPassword: webdavPassword.value
+			}, { timeout: 20000 });
+			let message = `DeepSeek：${response.deepseekConfigured ? '已配置' : '未配置'}\n`
+				+ `easyScholar：${response.easyScholarConfigured ? '已配置' : '未配置'}\n`
+				+ `WebDAV：${response.webdavConfigured ? '已配置' : '未配置'}`;
+			Services.prompt.alert(null, 'SciReader 设置', message);
+		}
+		catch (e) {
+			Services.prompt.alert(null, 'SciReader 设置失败', String(e));
+		}
+	};
+
+	this.configureKeys = this.configureSettings;
+
+	this.closeProgressTask = function (docID) {
+		let task = this._progressTasks.get(docID);
+		if (!task) {
+			return;
+		}
+		task.closed = true;
+		try {
+			task.progressWin.close();
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow progress close failed: ${e}`);
+		}
+		this._progressTasks.delete(docID);
+	};
+
+	this.closeAllProgress = function () {
+		for (let docID of Array.from(this._progressTasks.keys())) {
+			this.closeProgressTask(docID);
+		}
+	};
+
+	this.scheduleProgressClose = function (docID, delay = 2500) {
+		let task = this._progressTasks.get(docID);
+		if (!task || task.closeScheduled) {
+			return;
+		}
+		task.closeScheduled = true;
+		try {
+			task.progressWin.startCloseTimer(delay);
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow progress timer failed: ${e}`);
+		}
+		Zotero.Promise.delay(delay + 500).then(() => this.closeProgressTask(docID));
+	};
+
+	this.shouldHandleItem = function (item) {
+		return !!(
+			item
+			&& item.isFileAttachment()
+			&& item.attachmentContentType === 'application/pdf'
+		);
+	};
+
+	this.getTitle = function (item, path) {
+		if (item?.parentItemID) {
+			let parentItem = Zotero.Items.get(item.parentItemID);
+			if (parentItem) {
+				return parentItem.getField('title') || item.getField('title') || PathUtils.filename(path);
+			}
+		}
+		return item.getField('title') || PathUtils.filename(path);
+	};
+
+	this.cleanAttachmentTitle = function (item, path) {
+		let title = item.getField('title') || item.attachmentFilename || PathUtils.filename(path) || 'Untitled PDF';
+		if (title === item.attachmentFilename || title.endsWith('.pdf')) {
+			title = title.replace(/\.[^.]+$/, '');
+		}
+		return title
+			.replace(/[_]+/g, ' ')
+			.replace(/\s+-\s+\d{4}\s+-\s+/g, ' - ')
+			.replace(/\s+/g, ' ')
+			.trim() || 'Untitled PDF';
+	};
+
+	this.buildURL = function (endpoint, item, path, params = {}) {
+		let query = {
+			path,
+			itemID: item.id,
+			title: this.getTitle(item, path),
+			venue: this.getPublicationVenue(item),
+			...params
+		};
+		let pairs = [];
+		for (let [key, value] of Object.entries(query)) {
+			if (value === undefined || value === null) {
+				continue;
+			}
+			pairs.push(`${encodeURIComponent(key)}=${encodeURIComponent(value)}`);
+		}
+		return `${this.baseURL}${endpoint}?${pairs.join('&')}`;
+	};
+
+	this.jsonRequest = async function (url, options = {}) {
+		let response = await Zotero.HTTP.request('GET', url, {
+			timeout: options.timeout || 30000,
+			responseType: 'json'
+		});
+		if (response.response) {
+			return response.response;
+		}
+		return JSON.parse(response.responseText || '{}');
+	};
+
+	this.postJSON = async function (endpoint, body, options = {}) {
+		let response = await Zotero.HTTP.request('POST', `${this.baseURL}${endpoint}`, {
+			timeout: options.timeout || 30000,
+			headers: { 'Content-Type': 'application/json' },
+			body: JSON.stringify(body || {}),
+			responseType: 'json'
+		});
+		if (response.response) {
+			return response.response;
+		}
+		return JSON.parse(response.responseText || '{}');
+	};
+
+	this.delay = function (ms) {
+		return new Promise(resolve => setTimeout(resolve, ms));
+	};
+
+	this.shortTitle = function (text, maxLength = 46) {
+		text = String(text || '').replace(/\s+/g, ' ').trim();
+		if (text.length <= maxLength) {
+			return text;
+		}
+		return text.slice(0, maxLength - 3) + '...';
+	};
+
+	this.escapeHTML = function (text) {
+		return String(text || '')
+			.replace(/&/g, '&amp;')
+			.replace(/</g, '&lt;')
+			.replace(/>/g, '&gt;')
+			.replace(/"/g, '&quot;');
+	};
+
+	this.getPublicationVenue = function (item) {
+		let target = this.getColumnItem(item);
+		if (!target && item?.parentItemID) {
+			target = Zotero.Items.get(item.parentItemID);
+		}
+		target = target || item;
+		let fields = ['publicationTitle', 'conferenceName', 'proceedingsTitle', 'journalAbbreviation'];
+		for (let field of fields) {
+			try {
+				let value = target.getField(field);
+				if (value && String(value).trim()) {
+					return String(value).trim();
+				}
+			}
+			catch (e) {}
+		}
+		return '';
+	};
+
+	this.getColumnItem = function (item) {
+		if (!item) {
+			return null;
+		}
+		if (item.isRegularItem && item.isRegularItem()) {
+			return item;
+		}
+		if (item.parentItemID) {
+			let parentItem = Zotero.Items.get(item.parentItemID);
+			if (parentItem?.isRegularItem?.()) {
+				return parentItem;
+			}
+		}
+		return null;
+	};
+
+	this.parseAIExtra = function (item) {
+		let data = {};
+		if (!item?.getField) {
+			return data;
+		}
+		let extra = item.getField('extra') || '';
+		for (let line of extra.split(/\r?\n/)) {
+			let match = line.match(/^(?:AI Reflow|SciReader) (Venue|CCF|SCI|JCR|RankScore|Stars|CodeStatus|CodeURL|CodeEvidence|Evidence):\s*(.*)$/);
+			if (match) {
+				data[match[1]] = match[2].trim();
+			}
+		}
+		return data;
+	};
+
+	this.setAIExtra = function (item, updates) {
+		let existing = this.parseAIExtra(item);
+		let merged = { ...existing, ...updates };
+		let extra = item.getField('extra') || '';
+		let lines = extra
+			.split(/\r?\n/)
+			.filter(line => !/^(?:AI Reflow|SciReader) (Venue|CCF|SCI|JCR|RankScore|Stars|CodeStatus|CodeURL|CodeEvidence|Evidence):/.test(line));
+		while (lines.length && !lines[lines.length - 1].trim()) {
+			lines.pop();
+		}
+		if (lines.length) {
+			lines.push('');
+		}
+		for (let key of this.aiExtraKeys) {
+			let value = merged[key];
+			if (value !== undefined && value !== null && String(value).trim() !== '') {
+				lines.push(`SciReader ${key}: ${String(value).replace(/\s+/g, ' ').trim()}`);
+			}
+		}
+		item.setField('extra', lines.join('\n'));
+	};
+
+	this.rankScore = function (meta) {
+		let ccf = String(meta.CCF || '').toUpperCase();
+		let sci = String(meta.SCI || '').toUpperCase();
+		let jcr = String(meta.JCR || '').toUpperCase();
+		if (meta.RankScore !== undefined && meta.RankScore !== '') {
+			let parsed = parseInt(meta.RankScore, 10);
+			if (!isNaN(parsed)) {
+				return Math.max(0, Math.min(7, parsed));
+			}
+		}
+		let ccfScore = { A: 3, B: 2, C: 1 }[ccf] || 0;
+		let quartileScore = { Q1: 4, Q2: 3, Q3: 2, Q4: 1 };
+		return ccfScore + Math.max(quartileScore[sci] || 0, quartileScore[jcr] || 0);
+	};
+
+	this.normalizeStars = function (stars) {
+		let value = parseInt(stars, 10);
+		if (isNaN(value)) {
+			value = 0;
+		}
+		return Math.max(0, Math.min(5, value));
+	};
+
+	this.sortCellData = function (score, display) {
+		score = parseInt(score, 10);
+		if (isNaN(score)) {
+			score = 0;
+		}
+		return `${String(Math.max(0, score)).padStart(4, '0')}|${display || ''}`;
+	};
+
+	this.displayCellData = function (data) {
+		data = String(data || '');
+		let match = data.match(/^\d{4}\|(.*)$/s);
+		return match ? match[1] : data;
+	};
+
+	this.summaryToNoteHTML = function (summary, savedPath) {
+		let pathHTML = savedPath
+			? `<p><strong>本地摘要文件：</strong>${this.escapeHTML(savedPath)}</p>`
+			: '';
+		return (
+			`<div data-ai-reflow-summary="1">`
+			+ `<h1>${this.summaryNoteTitle}</h1>`
+			+ pathHTML
+			+ `<pre style="white-space: pre-wrap; font-family: inherit;">${this.escapeHTML(summary)}</pre>`
+			+ `</div>`
+		);
+	};
+
+	this.getCurrentItem = async function (item) {
+		return (await Zotero.Items.getAsync(item.id)) || item;
+	};
+
+	this.getSummaryParentItem = async function (item) {
+		let currentItem = await this.getCurrentItem(item);
+		if (currentItem.parentItemID) {
+			return Zotero.Items.get(currentItem.parentItemID);
+		}
+		return currentItem;
+	};
+
+	this.ensureParentItem = async function (item, options = {}) {
+		let currentItem = await this.getCurrentItem(item);
+		if (!this.shouldHandleItem(currentItem) || currentItem.parentItemID || !currentItem.isTopLevelItem()) {
+			return currentItem;
+		}
+		let title = options.title || this.cleanAttachmentTitle(currentItem, options.path);
+		try {
+			let parentItem = new Zotero.Item('document');
+			parentItem.libraryID = currentItem.libraryID;
+			parentItem.setField('title', title);
+			let collections = currentItem.getCollections();
+			if (collections.length) {
+				parentItem.setCollections(collections);
+			}
+			await Zotero.DB.executeTransaction(async () => {
+				let parentID = await parentItem.save();
+				currentItem.parentID = parentID;
+				currentItem.setField('title', 'Full Text PDF');
+				await currentItem.save();
+			});
+			Zotero.debug(`AI Reflow created fallback parent item for PDF ${currentItem.id}`);
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow fallback parent creation failed: ${e}`);
+		}
+		return this.getCurrentItem(currentItem);
+	};
+
+	this.looksLikeFallbackTitle = function (title, item, path) {
+		title = String(title || '').replace(/\s+/g, ' ').trim();
+		if (!title || title === 'Untitled PDF' || title === 'Full Text PDF') {
+			return true;
+		}
+		if (/^\d{4}\.\d{4,}(v\d+)?$/i.test(title)) {
+			return true;
+		}
+		let stem = '';
+		try {
+			stem = PathUtils.filename(path || item?.attachmentFilename || '').replace(/\.[^.]+$/, '');
+		}
+		catch (e) {}
+		let cleanStem = stem.replace(/[_]+/g, ' ').replace(/\s+/g, ' ').trim();
+		return !!(
+			stem
+			&& (
+				title === stem
+				|| title === cleanStem
+				|| title === this.cleanAttachmentTitle(item, path)
+			)
+		);
+	};
+
+	this.updateParentFromMetadata = async function (item, path, docID, metadata = null) {
+		if (!docID) {
+			return false;
+		}
+		let response = metadata;
+		if (!response) {
+			response = await this.jsonRequest(
+				`${this.baseURL}/api/metadata?id=${encodeURIComponent(docID)}`,
+				{ timeout: 90000 }
+			);
+		}
+		if (!response || response.status) {
+			return false;
+		}
