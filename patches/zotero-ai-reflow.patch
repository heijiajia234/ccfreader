+		let update = (status) => {
+			let task = this._progressTasks.get(docID);
+			if (!task || task.closed) {
+				return false;
+			}
+			let percent = Math.max(0, Math.min(100, Math.round(status.progress || 0)));
+			let stage = status.stage || status.status || 'working';
+			itemProgress.setText(`${title} - ${stage} ${percent}%`);
+			itemProgress.setProgress(percent);
+			return true;
+		};
+		update(initialStatus);
+		if (initialStatus.status === 'ready') {
+			itemProgress.setText(`${title} - done 100%`);
+			itemProgress.setProgress(100);
+			this.scheduleProgressClose(docID, 2500);
+			return;
+		}
