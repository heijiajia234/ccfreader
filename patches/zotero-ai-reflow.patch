+						itemProgress.setError();
+						this.scheduleProgressClose(docID, 12000);
+						return;
+					}
+				}
+				itemProgress.setText(`${title} - still running`);
+				this.scheduleProgressClose(docID, 8000);
+			}
+			catch (e) {
+				if (this._progressTasks.has(docID)) {
