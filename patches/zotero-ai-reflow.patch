diff --git a/chrome/content/zotero/xpcom/aiReflow.js b/chrome/content/zotero/xpcom/aiReflow.js
new file mode 100644
index 0000000..32d46d6
--- /dev/null
+++ b/chrome/content/zotero/xpcom/aiReflow.js
@@ -0,0 +1,464 @@
+/*
+    Local AI reflow bridge for PDF attachments.
+*/
+
+Zotero.AIReflow = new function () {
+	this.baseURL = 'http://127.0.0.1:27621';
+	this.summaryNoteTitle = 'AI Reflow 论文总结';
+	this._summaryNoteTasks = new Set();
+	this._metadataTasks = new Set();
+	this._progressTasks = new Map();
+
+	this.isProgressEnabled = function () {
+		try {
+			return Zotero.Prefs.get('aiReflow.showProgress') !== false;
+		}
+		catch (e) {
+			return true;
+		}
+	};
+
+	this.setProgressEnabled = function (enabled) {
+		Zotero.Prefs.set('aiReflow.showProgress', !!enabled);
+		if (!enabled) {
+			this.closeAllProgress();
+		}
+	};
+
+	this.closeProgressTask = function (docID) {
+		let task = this._progressTasks.get(docID);
+		if (!task) {
+			return;
+		}
+		task.closed = true;
+		try {
+			task.progressWin.close();
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow progress close failed: ${e}`);
+		}
+		this._progressTasks.delete(docID);
+	};
+
+	this.closeAllProgress = function () {
+		for (let docID of Array.from(this._progressTasks.keys())) {
+			this.closeProgressTask(docID);
+		}
+	};
+
+	this.scheduleProgressClose = function (docID, delay = 2500) {
+		let task = this._progressTasks.get(docID);
+		if (!task || task.closeScheduled) {
+			return;
+		}
+		task.closeScheduled = true;
+		try {
+			task.progressWin.startCloseTimer(delay);
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow progress timer failed: ${e}`);
+		}
+		Zotero.Promise.delay(delay + 500).then(() => this.closeProgressTask(docID));
+	};
+
+	this.shouldHandleItem = function (item) {
+		return !!(
+			item
+			&& item.isFileAttachment()
+			&& item.attachmentContentType === 'application/pdf'
+		);
+	};
+
+	this.getTitle = function (item, path) {
+		if (item?.parentItemID) {
+			let parentItem = Zotero.Items.get(item.parentItemID);
+			if (parentItem) {
+				return parentItem.getField('title') || item.getField('title') || PathUtils.filename(path);
+			}
+		}
+		return item.getField('title') || PathUtils.filename(path);
+	};
+
+	this.cleanAttachmentTitle = function (item, path) {
+		let title = item.getField('title') || item.attachmentFilename || PathUtils.filename(path) || 'Untitled PDF';
+		if (title === item.attachmentFilename || title.endsWith('.pdf')) {
+			title = title.replace(/\.[^.]+$/, '');
+		}
+		return title
+			.replace(/[_]+/g, ' ')
+			.replace(/\s+-\s+\d{4}\s+-\s+/g, ' - ')
+			.replace(/\s+/g, ' ')
+			.trim() || 'Untitled PDF';
+	};
+
+	this.buildURL = function (endpoint, item, path, params = {}) {
+		let query = {
+			path,
+			itemID: item.id,
+			title: this.getTitle(item, path),
+			...params
+		};
+		let pairs = [];
+		for (let [key, value] of Object.entries(query)) {
+			if (value === undefined || value === null) {
+				continue;
+			}
+			pairs.push(`${encodeURIComponent(key)}=${encodeURIComponent(value)}`);
+		}
+		return `${this.baseURL}${endpoint}?${pairs.join('&')}`;
+	};
+
+	this.jsonRequest = async function (url, options = {}) {
+		let response = await Zotero.HTTP.request('GET', url, {
+			timeout: options.timeout || 30000,
+			responseType: 'json'
+		});
+		if (response.response) {
+			return response.response;
+		}
+		return JSON.parse(response.responseText || '{}');
+	};
+
+	this.delay = function (ms) {
+		return new Promise(resolve => setTimeout(resolve, ms));
+	};
+
+	this.shortTitle = function (text, maxLength = 46) {
+		text = String(text || '').replace(/\s+/g, ' ').trim();
+		if (text.length <= maxLength) {
+			return text;
+		}
+		return text.slice(0, maxLength - 3) + '...';
+	};
+
+	this.escapeHTML = function (text) {
+		return String(text || '')
+			.replace(/&/g, '&amp;')
+			.replace(/</g, '&lt;')
+			.replace(/>/g, '&gt;')
+			.replace(/"/g, '&quot;');
+	};
+
+	this.summaryToNoteHTML = function (summary, savedPath) {
+		let pathHTML = savedPath
+			? `<p><strong>本地摘要文件：</strong>${this.escapeHTML(savedPath)}</p>`
+			: '';
+		return (
+			`<div data-ai-reflow-summary="1">`
+			+ `<h1>${this.summaryNoteTitle}</h1>`
+			+ pathHTML
+			+ `<pre style="white-space: pre-wrap; font-family: inherit;">${this.escapeHTML(summary)}</pre>`
+			+ `</div>`
+		);
+	};
+
+	this.getCurrentItem = async function (item) {
+		return (await Zotero.Items.getAsync(item.id)) || item;
+	};
+
+	this.getSummaryParentItem = async function (item) {
+		let currentItem = await this.getCurrentItem(item);
+		if (currentItem.parentItemID) {
+			return Zotero.Items.get(currentItem.parentItemID);
+		}
+		return currentItem;
+	};
+
+	this.ensureParentItem = async function (item, options = {}) {
+		let currentItem = await this.getCurrentItem(item);
+		if (!this.shouldHandleItem(currentItem) || currentItem.parentItemID || !currentItem.isTopLevelItem()) {
+			return currentItem;
+		}
+		let title = options.title || this.cleanAttachmentTitle(currentItem, options.path);
+		try {
+			let parentItem = new Zotero.Item('document');
+			parentItem.libraryID = currentItem.libraryID;
+			parentItem.setField('title', title);
+			let collections = currentItem.getCollections();
+			if (collections.length) {
+				parentItem.setCollections(collections);
+			}
+			await Zotero.DB.executeTransaction(async () => {
+				let parentID = await parentItem.save();
+				currentItem.parentID = parentID;
+				currentItem.setField('title', 'Full Text PDF');
+				await currentItem.save();
+			});
+			Zotero.debug(`AI Reflow created fallback parent item for PDF ${currentItem.id}`);
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow fallback parent creation failed: ${e}`);
+		}
+		return this.getCurrentItem(currentItem);
+	};
+
+	this.saveSummaryNote = async function (item, summary, savedPath) {
+		item = await this.ensureParentItem(item);
+		let parentItem = await this.getSummaryParentItem(item);
+		if (!parentItem || parentItem.isNote()) {
+			return false;
+		}
+		await parentItem.loadDataType('childItems');
+		let noteHTML = this.summaryToNoteHTML(summary, savedPath);
+		let notes = Zotero.Items.get(parentItem.getNotes(true));
+		let note = notes.find(note => {
+			let content = note.getNote();
+			return content.includes('data-ai-reflow-summary="1"')
+				|| note.getNoteTitle() == this.summaryNoteTitle;
+		});
+		if (!note) {
+			note = new Zotero.Item('note');
+			note.libraryID = parentItem.libraryID;
+			note.parentID = parentItem.id;
+		}
+		note.setNote(noteHTML);
+		await note.saveTx();
+		return true;
+	};
+
+	this.queueSummaryNote = function (item, docID) {
+		let key = `${item.id}:${docID}`;
+		if (this._summaryNoteTasks.has(key)) {
+			return;
+		}
+		this._summaryNoteTasks.add(key);
+		(async () => {
+			try {
+				for (let i = 0; i < 120; i++) {
+					let url = `${this.baseURL}/api/summary?id=${encodeURIComponent(docID)}`;
+					let response;
+					try {
+						response = await this.jsonRequest(url, { timeout: 240000 });
+					}
+					catch (e) {
+						Zotero.debug(`AI Reflow summary note poll failed: ${e}`);
+						await this.delay(5000);
+						continue;
+					}
+					if (response.text) {
+						await this.saveSummaryNote(item, response.text, response.savedPath);
+						return;
+					}
+					await this.delay(5000);
+				}
+			}
+			finally {
+				this._summaryNoteTasks.delete(key);
+			}
+		})();
+	};
+
+	this.queueItemAfterMetadata = function (item, options = {}) {
+		if (!this.shouldHandleItem(item)) {
+			return false;
+		}
+		let key = String(item.id);
+		if (this._metadataTasks.has(key)) {
+			return true;
+		}
+		this._metadataTasks.add(key);
+		(async () => {
+			try {
+				await this.delay(options.metadataDelay || 1000);
+				let currentItem = await this.getCurrentItem(item);
+				if (!this.shouldHandleItem(currentItem)) {
+					return;
+				}
+				if (
+					options.recognize !== false
+					&& Zotero.RecognizeDocument
+					&& Zotero.RecognizeDocument.canRecognize(currentItem)
+				) {
+					try {
+						await Promise.race([
+							Zotero.RecognizeDocument.recognizeItems([currentItem]),
+							this.delay(options.recognizeTimeout || 120000)
+						]);
+					}
+					catch (e) {
+						Zotero.debug(`AI Reflow metadata recognition failed: ${e}`);
+					}
+					currentItem = await this.getCurrentItem(item);
+				}
+				currentItem = await this.ensureParentItem(currentItem, options);
+				await this.queueItem(currentItem, options);
+			}
+			catch (e) {
+				Zotero.debug(`AI Reflow metadata queue failed: ${e}`);
+			}
+			finally {
+				this._metadataTasks.delete(key);
+			}
+		})();
+		return true;
+	};
+
+	this.showProgressError = function (item, path, message) {
+		if (!this.isProgressEnabled()) {
+			return;
+		}
+		try {
+			let progressWin = new Zotero.ProgressWindow({ closeOnClick: true });
+			progressWin.changeHeadline('AI Reflow Background');
+			let title = this.shortTitle(this.getTitle(item, path));
+			let itemProgress = new progressWin.ItemProgress('attachmentPDF', `${title} - ${message}`);
+			progressWin.show();
+			itemProgress.setError();
+			progressWin.startCloseTimer(10000);
+			Zotero.Promise.delay(10500).then(() => {
+				try {
+					progressWin.close();
+				}
+				catch (e) {}
+			});
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow progress error failed: ${e}`);
+		}
+	};
+
+	this.trackProgress = function (docID, item, path, initialStatus = {}) {
+		if (!docID || this._progressTasks.has(docID) || !this.isProgressEnabled()) {
+			return;
+		}
+		let progressWin = new Zotero.ProgressWindow({ closeOnClick: true });
+		progressWin.changeHeadline('AI Reflow Background');
+		let title = this.shortTitle(this.getTitle(item, path));
+		let itemProgress = new progressWin.ItemProgress('attachmentPDF', `${title} - queued 0%`);
+		progressWin.show();
+		this._progressTasks.set(docID, { progressWin, itemProgress, closed: false });
+
+		let update = (status) => {
+			let task = this._progressTasks.get(docID);
+			if (!task || task.closed) {
+				return false;
+			}
+			let percent = Math.max(0, Math.min(100, Math.round(status.progress || 0)));
+			let stage = status.stage || status.status || 'working';
+			itemProgress.setText(`${title} - ${stage} ${percent}%`);
+			itemProgress.setProgress(percent);
+			return true;
+		};
+		update(initialStatus);
+		if (initialStatus.status === 'ready') {
+			itemProgress.setText(`${title} - done 100%`);
+			itemProgress.setProgress(100);
+			this.scheduleProgressClose(docID, 2500);
+			return;
+		}
+
+		(async () => {
+			try {
+				for (let i = 0; i < 600; i++) {
+					await this.delay(1400);
+					let task = this._progressTasks.get(docID);
+					if (!task || task.closed || !this.isProgressEnabled()) {
+						return;
+					}
+					let status = await this.jsonRequest(
+						`${this.baseURL}/api/status?id=${encodeURIComponent(docID)}`,
+						{ timeout: 8000 }
+					);
+					if (!update(status)) {
+						return;
+					}
+					if (status.status === 'ready') {
+						itemProgress.setText(`${title} - done 100%`);
+						itemProgress.setProgress(100);
+						this.scheduleProgressClose(docID, 2500);
+						return;
+					}
+					if (status.status === 'error') {
+						let error = this.shortTitle(status.error || 'failed', 80);
+						itemProgress.setText(`${title} - ${error}`);
+						itemProgress.setError();
+						this.scheduleProgressClose(docID, 12000);
+						return;
+					}
+				}
+				itemProgress.setText(`${title} - still running`);
+				this.scheduleProgressClose(docID, 8000);
+			}
+			catch (e) {
+				if (this._progressTasks.has(docID)) {
+					itemProgress.setText(`${title} - status failed`);
+					itemProgress.setError();
+					this.scheduleProgressClose(docID, 10000);
+				}
+			}
+		})();
+	};
+
+	this.maximizeViewerWindow = function (win) {
+		if (!win) {
+			return;
+		}
+		let maximize = () => {
+			try {
+				win.moveTo(0, 0);
+				win.resizeTo(win.screen.availWidth, win.screen.availHeight);
+				win.maximize();
+				win.focus();
+			}
+			catch (e) {
+				Zotero.debug(`AI Reflow could not maximize viewer: ${e}`);
+			}
+		};
+		try {
+			win.addEventListener('load', () => win.setTimeout(maximize, 0), { once: true });
+		}
+		catch (e) {}
+		win.setTimeout(maximize, 250);
+	};
+
+	this.queueItem = async function (item, options = {}) {
+		if (!this.shouldHandleItem(item)) {
+			return false;
+		}
+		item = await this.getCurrentItem(item);
+		let path = options.path || await item.getFilePathAsync();
+		if (!path) {
+			return false;
+		}
+		item = await this.ensureParentItem(item, { path });
+		let url = this.buildURL('/api/ingest', item, path, {
+			translate: options.translate === false ? '0' : '1',
+			force: options.force ? '1' : '0'
+		});
+		try {
+			let response = await this.jsonRequest(url, {
+				timeout: options.timeout || 15000,
+			});
+			if (response.id && options.showProgress !== false) {
+				this.trackProgress(response.id, item, path, response);
+			}
+			if (response.id && options.summaryNote !== false) {
+				this.queueSummaryNote(item, response.id);
+			}
+			return true;
+		}
+		catch (e) {
+			Zotero.debug(`AI Reflow service unavailable for ${path}: ${e}`);
+			if (options.showProgress !== false) {
+				this.showProgressError(item, path, 'service unavailable');
+			}
+			return false;
+		}
+	};
+
+	this.openItem = async function (item, options = {}) {
+		if (!this.shouldHandleItem(item)) {
+			return false;
+		}
+		item = await this.getCurrentItem(item);
+		let path = options.path || await item.getFilePathAsync();
+		if (!path) {
+			return false;
+		}
+		item = await this.ensureParentItem(item, { path });
+		await this.queueItem(item, { path, timeout: 3000 });
+		let win = Zotero.openInViewer(this.buildURL('/reflow', item, path), { allowJavaScript: true });
+		this.maximizeViewerWindow(win);
+		return true;
+	};
+};
